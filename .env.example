# Server-side PostgREST base URL (never exposed to the browser). Change per environment.
# The API surface matches `helpers/railway/db/*.sql` (tables, views, RPCs) — see OpenAPI at GET {POSTGREST_URL}/ when in doubt.
#
# Development (Rancher Desktop + Traefik on this machine): stable host per UIS wiring.
POSTGREST_URL=http://api-railway.localhost
#
# Production / in-cluster Next.js: override with the Service URL, e.g.
#   http://railway-postgrest.postgrest.svc.cluster.local:3000
# If your gateway adds a path prefix (e.g. /rest/v1), include it on this value so it matches PostgREST.

# JWT for the anon role — required for server reads without a staff session (`08-auth.md`).
POSTGREST_ANON_JWT=

# Optional — comma-separated origins; POST /api/registrations kræver matching Origin eller Referer (full URL‑origin‑match, ikke prefiks).
# Avviser også Sec-Fetch-Site: cross-site med mindre REGISTRATION_RELAX_FETCH_METADATA=1 (for eksotiske proxyer).
# Eksempel: http://localhost:3001 eller https://railway.example,https://staging.example
# PRIMARY_SITE_URL=

# Tillat POST /api/registrations uten Sec-Fetch-Site‑sperre mot cross-site (kun hvis du vet hvorfor):
# REGISTRATION_RELAX_FETCH_METADATA=

# ── Admin (JWT-økt + valgfritt bootstrap-passord, se 08-auth) ────────────────────
# Samme Hemmelighet som PostgREST bruker til å verifisere HS256 staff-JWT:
JWT_SECRET=
# Valgfritt dev-bootstrap: mint bred staff-JWT ved innlogging (krever også JWT_SECRET):
ADMIN_PASSWORD=
# PostgREST staff JWT — fallback når ingen økt-cookie (capabilities: registrations:read+, se 08-auth).
# UIS kan levere kun én av disse:
POSTGREST_ADMIN_JWT=
# Full kapabilitetsliste fra UIS configure (prioriteres ikke — brukes bare hvis linjen over er tom):
POSTGREST_STAFF_JWT_UIS=

# I produksjon: sett til 1 for å tillate GET /api/admin/bootstrap-session (setter økt fra miljø‑JWT). Farlig på åpent nett.
# ADMIN_BOOTSTRAP_SESSION_FROM_ENV=

# Til lokal minting når JWT_SECRET matcher PostgREST: node scripts/mint-staff-jwt.mjs
