# Server-side PostgREST base URL (UIS cluster; not exposed to the browser).
# Example when PostgREST is routed on the local UIS stack:
# POSTGREST_URL=http://postgrest.railway.svc.cluster.local:3000
POSTGREST_URL=

# Optional: long-lived anon JWT for RSC/server calls (see terchris/new docs).
# POSTGREST_ANON_JWT=
