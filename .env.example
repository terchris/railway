# Server-side PostgREST base URL (never exposed to the browser). Change per environment.
# The API surface matches `helpers/railway/db/*.sql` (tables, views, RPCs) — see OpenAPI at GET {POSTGREST_URL}/ when in doubt.
#
# Development (Rancher Desktop + Traefik on this machine): stable host per UIS wiring.
POSTGREST_URL=http://api-railway.localhost
#
# Production / in-cluster Next.js: override with the Service URL, e.g.
#   http://railway-postgrest.postgrest.svc.cluster.local:3000
# If your gateway adds a path prefix (e.g. /rest/v1), include it on this value so it matches PostgREST.

# JWT for the anon role — required for server reads without a staff session (`08-auth.md`).
POSTGREST_ANON_JWT=

# Optional — if set, POST /api/registrations rejects bodies whose Origin/Referer does not start here (e.g. http://localhost:3001).
# PRIMARY_SITE_URL=

# ── Admin (enkel lokallogin; ikke erstatter for JWT / 08-auth) ─────────────────
ADMIN_PASSWORD=
# Lang tilfeldig streng brukt til HMAC-signering av økt-cookie:
ADMIN_COOKIE_SECRET=
# PostgREST JWT med registrations:read (og ev. mer) fra UIS — liste i /admin/registrations:
POSTGREST_ADMIN_JWT=
